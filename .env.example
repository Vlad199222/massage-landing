# Скопіюй у .env.local або задай у Railway → Variables.
# Токен видає @BotFather після /newbot
TELEGRAM_BOT_TOKEN=123456789:AAABBBcccDDDeeeFFFgggHHH

# chat_id: особистий чат з ботом (позитивне число) АБО група/супергрупа (від’ємне, напр. -5298193940).
# Для групи: додайте бота в групу, надішліть повідомлення, потім getUpdates.
# https://api.telegram.org/bot<TOKEN>/getUpdates — поле message.chat.id
TELEGRAM_CHAT_ID=-1001234567890
